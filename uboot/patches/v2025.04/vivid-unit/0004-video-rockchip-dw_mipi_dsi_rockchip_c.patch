+static void dw_mipi_dsi_rockchip_apply_lcdsel(struct dw_rockchip_dsi_priv *dsi,
+					    struct udevice *dev)
+{
+	bool force_vopb = dev_read_bool(dev, "vivid-unit,force-vopb-lcdc");
+	bool force_vopl = dev_read_bool(dev, "vivid-unit,force-vopl-lcdc");
+	u32 before, after, val;
+
+	if (!dsi->cdata->lcdsel_grf_reg)
+		return;
+
+	before = readl(dsi->grf + dsi->cdata->lcdsel_grf_reg);
+	if (force_vopb)
+		val = dsi->cdata->lcdsel_big;
+	else if (force_vopl)
+		val = dsi->cdata->lcdsel_lit;
+	else {
+		printf("dw-mipi-dsi-rockchip: lcdsel unchanged reg=%#x before=%#x\n",
+		       dsi->cdata->lcdsel_grf_reg, before);
+		return;
+	}
+
+	rk_setreg(dsi->grf + dsi->cdata->lcdsel_grf_reg, val);
+	after = readl(dsi->grf + dsi->cdata->lcdsel_grf_reg);
+	printf("dw-mipi-dsi-rockchip: lcdsel override=%s reg=%#x write=%#x before=%#x after=%#x\n",
+	       force_vopb ? "vopb/big" : "vopl/lit",
+	       dsi->cdata->lcdsel_grf_reg, val, before, after);
+}
